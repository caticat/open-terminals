{
  "name": "open-terminals",
  "displayName": "open terminals",
  "description": "Open multiple terminals in the editor area from a config file",
  "publisher": "panjie039",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/caticat/open-terminals"
  },
  "license": "MIT",
  "icon": "assets/icon.png",
  "engines": {
    "vscode": ">=1.80.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "open-terminals.run",
        "title": "Open Terminals - Open (Editor Area)"
      },
      {
        "command": "open-terminals.close",
        "title": "Open Terminals - Close All"
      }
    ],
    "keybindings": [
      {
        "command": "open-terminals.run",
        "key": "ctrl+alt+t",
        "when": "editorTextFocus || !terminalFocus"
      },
      {
        "command": "open-terminals.close",
        "key": "ctrl+alt+w",
        "when": "editorTextFocus || !terminalFocus"
      }
    ],
    "configuration": {
      "title": "Open Terminals",
      "properties": {
        "openTerminals.shellInitDelay": {
          "type": "number",
          "default": 500,
          "minimum": 0,
          "description": "Delay (ms) before sending command to each terminal, allowing the shell to initialize."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "@types/js-yaml": "^4.0.5",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  }
}
